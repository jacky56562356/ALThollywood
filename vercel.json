{
  "version": 2,
  "functions": {
    "api/submit-form.js": {
      "runtime": "@vercel/node"
    }
  },
  "routes": [
    {
      "src": "/api/submit-form",
      "dest": "/api/submit-form.js"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
